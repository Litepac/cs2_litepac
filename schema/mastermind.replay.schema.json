        "flashbangs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/nullableInteger"
          }
        },
        "smokes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/nullableInteger"
          }
        },
        "heGrenades": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/nullableInteger"
          }
        },
        "fireGrenades": {
          "type": "array",
